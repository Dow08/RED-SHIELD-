# ============================================================
# RED — Configuration d'exemple. Copier en `.env` et adapter.
# AUCUN secret réel dans ce fichier (il est versionné).
# ============================================================

# --- Réseau / API locale ---
# L'API se lie à 127.0.0.1 par défaut (sécurité). Passer à 0.0.0.0
# UNIQUEMENT pour la consultation mobile sur le LAN (+ jeton requis).
RED_HOST=127.0.0.1
RED_PORT=8787

# --- Mode de fonctionnement ---
# air-gapped ACTIF par défaut : coupe tout appel réseau externe.
RED_AIRGAPPED=true
# Intervalle d'échantillonnage du bouclier (secondes)
RED_SAMPLE_INTERVAL=2

# --- Base de données ---
RED_DB_PATH=engine/data/red.db

# --- Rétention & stockage ---
RED_STORAGE_BUDGET_GO=1.0
RED_PURGE_ON_EXIT=true

# --- Clés API des connecteurs (laisser vide ; stockage réel via keyring) ---
# Ne s'activent QUE si RED_AIRGAPPED=false.
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
GREYNOISE_API_KEY=
SHODAN_API_KEY=
NVD_API_KEY=

# --- SIEM / EDR (optionnels, J4) ---
WAZUH_ENDPOINT=
WAZUH_TOKEN=

# --- Rapport IA (optionnel ; inerte si air-gapped) ---
# Laisser vide, ou pointer un LLM local (ex: http://localhost:11434 pour Ollama).
LLM_API_URL=
LLM_API_KEY=
